# Cohere API key for the analytics agent
COHERE_API_KEY=

# Optional: Cohere model for the analytics agent (default: command-r-plus-08-2024).
# Try command-r-08-2024 if you want a faster, smaller model.
# COHERE_MODEL=command-r-plus-08-2024

# Supabase project URL (public) — used by resolve_entity for player/team lookups
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service role key (server-only — never expose to the browser).
# Used only for typed reads from player_mapping / team_mapping via PostgREST.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for the read-only footquery_readonly role.
# See scripts/create-readonly-role.sql for how to create it.
#   postgresql://footquery_readonly:<password>@<host>:5432/postgres
DATABASE_URL=

# Secret used to sign the anonymous quota cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Optional: max messages per window (default 5)
# CHAT_MESSAGE_LIMIT=5

# Optional: window size in minutes (default 1440 = 24h). Lower for testing.
# CHAT_WINDOW_MINUTES=1440

# LangSmith observability — auto-traces every LangChain/LangGraph call when enabled.
# Get an API key at https://smith.langchain.com.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=footquery
# Default endpoint is fine for most users; override if you're on a self-hosted instance.
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
